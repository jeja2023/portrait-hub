# Strict production profile for PortraitHub.

PORTRAIT_RUNTIME_PROFILE=production
PRODUCTION_EXTERNAL_SERVICES_REQUIRED=true

AUTH_REQUIRED=true
RBAC_ENABLED=true
ENABLE_API_DOCS=false
DEBUG_ENDPOINTS_ENABLED=false
TENANT_HEADER_REQUIRED=true
JWT_REQUIRE_EXP=true
JWT_REQUIRE_ISS=true
JWT_REQUIRE_AUD=true
JWT_REQUIRE_TENANT=true

REQUIRE_ENCRYPTION=true
MODEL_CONFIG_READ_FAIL_CLOSED=true
AUDIT_WRITE_FAIL_CLOSED=true
STATE_READ_FAIL_CLOSED=true
STATE_WRITE_FAIL_CLOSED=true

PORTRAIT_STORAGE_BACKEND=postgres
PORTRAIT_VECTOR_BACKEND=pgvector
PORTRAIT_REQUIRE_PRODUCTION_VECTOR_BACKEND=true
PORTRAIT_REQUIRE_PRODUCTION_MODEL_CAPABILITIES=true
PORTRAIT_OBJECT_STORAGE_BACKEND=s3
TASK_QUEUE_BACKEND=redis

POSTGRES_DSN=
S3_BUCKET=
S3_REGION=us-east-1
S3_ENDPOINT_URL=
REDIS_URL=
QDRANT_URL=
QDRANT_API_KEY=

READY_CHECK_DEPENDENCIES=true
OPENTELEMETRY_ENABLED=true
OTEL_SERVICE_NAME=portrait-hub
OTEL_EXPORTER_OTLP_ENDPOINT=http://otel-collector:4318/v1/traces

ALLOW_STREAM_URLS=false
ALLOW_PRIVATE_STREAM_HOSTS=false
STREAM_ALLOWED_HOSTS=

SECURITY_HEADERS_ENABLED=true
HSTS_ENABLED=true
HSTS_MAX_AGE_SECONDS=31536000
HSTS_INCLUDE_SUBDOMAINS=true
HSTS_PRELOAD=false

RATE_LIMIT_PER_MINUTE=120
RATE_LIMIT_BURST=240
RATE_LIMIT_MAX_BUCKETS=10000
RATE_LIMIT_BUCKET_TTL_SECONDS=3600
MAX_REQUEST_BODY_BYTES=805306368

CPU_FALLBACK_ENABLED=false
