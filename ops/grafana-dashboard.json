{
  "title": "PortraitHub Overview",
  "schemaVersion": 39,
  "version": 1,
  "panels": [
    {
      "type": "timeseries",
      "title": "HTTP Request Rate",
      "targets": [{"expr": "sum(rate(gpu_worker_requests_total[5m]))"}]
    },
    {
      "type": "timeseries",
      "title": "Inference p95 Latency",
      "targets": [{"expr": "histogram_quantile(0.95, sum(rate(gpu_worker_inference_seconds_bucket[5m])) by (le))"}]
    },
    {
      "type": "timeseries",
      "title": "Decode p95 Latency",
      "targets": [{"expr": "histogram_quantile(0.95, sum(rate(gpu_worker_decode_seconds_bucket[5m])) by (le))"}]
    },
    {
      "type": "timeseries",
      "title": "Queue Wait p95",
      "targets": [{"expr": "histogram_quantile(0.95, sum(rate(gpu_worker_queue_seconds_bucket[5m])) by (le))"}]
    },
    {
      "type": "timeseries",
      "title": "GPU Memory Used",
      "targets": [{"expr": "gpu_worker_gpu_memory_used_bytes"}]
    },
    {
      "type": "timeseries",
      "title": "GPU Queue Depth",
      "targets": [{"expr": "gpu_worker_gpu_device_queue_depth"}]
    },
    {
      "type": "timeseries",
      "title": "Sessions by Provider",
      "targets": [{"expr": "sum by (provider) (gpu_worker_model_session_provider_total)"}]
    },
    {
      "type": "timeseries",
      "title": "CPU Fallback Rate",
      "targets": [{"expr": "sum by (reason) (rate(gpu_worker_cpu_fallback_total[5m]))"}]
    },
    {
      "type": "timeseries",
      "title": "Stream Reconnects & Backpressure Drops",
      "targets": [
        {"expr": "sum(increase(gpu_worker_stream_reconnects_total[5m]))"},
        {"expr": "sum(increase(gpu_worker_stream_backpressure_drops_total[5m]))"}
      ]
    },
    {
      "type": "timeseries",
      "title": "Video Decode Backend Usage",
      "targets": [{"expr": "sum by (backend) (rate(gpu_worker_video_decode_backend_total[5m]))"}]
    },
    {
      "type": "timeseries",
      "title": "Video Frame Sampling Rate",
      "targets": [
        {"expr": "rate(gpu_worker_video_frames_considered_total[5m])", "legendFormat": "considered"},
        {"expr": "rate(gpu_worker_video_frames_selected_total[5m])", "legendFormat": "selected"},
        {"expr": "rate(gpu_worker_video_near_duplicate_drops_total[5m])", "legendFormat": "near_dup_drops"}
      ]
    },
    {
      "type": "timeseries",
      "title": "Video Frame Quality Distribution (p50/p95)",
      "targets": [
        {"expr": "histogram_quantile(0.5, sum(rate(gpu_worker_video_frame_quality_bucket[5m])) by (le))", "legendFormat": "p50"},
        {"expr": "histogram_quantile(0.95, sum(rate(gpu_worker_video_frame_quality_bucket[5m])) by (le))", "legendFormat": "p95"}
      ]
    },
    {
      "type": "timeseries",
      "title": "Stream Frames Processed & Sampled",
      "targets": [
        {"expr": "rate(gpu_worker_stream_frames_processed_total[5m])", "legendFormat": "processed"},
        {"expr": "rate(gpu_worker_stream_frames_sampled_total[5m])", "legendFormat": "sampled"}
      ]
    },
    {
      "type": "stat",
      "title": "Loaded Models",
      "targets": [{"expr": "sum(gpu_worker_loaded_models)"}]
    }
  ]
}
