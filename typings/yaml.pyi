# 简体中文：YAML 模块的类型声明存根文件
from typing import Any, IO

def safe_load(stream: Any) -> Any: ...
def safe_dump(
    data: Any,
    stream: IO[str] | None = ...,
    *args: Any,
    **kwargs: Any,
) -> str | None: ...
def load(stream: Any, *args: Any, **kwargs: Any) -> Any: ...
def dump(data: Any, stream: IO[str] | None = ..., *args: Any, **kwargs: Any) -> str | None: ...
