# GPU 推理服务环境配置模板
# 使用方式：
#   cp .env.example .env
#   nano .env
#
# 注意：
# - docker compose 会自动读取同目录下的 .env。
# - 修改 .env 后，需要执行 docker compose up -d 让容器重新创建并加载新环境变量。
# - 生产环境不要把真实 .env 提交到 Git。

# 日志级别：DEBUG / INFO / WARNING / ERROR
LOG_LEVEL=INFO

# 宿主机模型共享目录。
# 默认 ./models 表示本项目目录下的 models。
# 容器内会只读挂载为 /models。
MODELS_HOST_DIR=./models

# 宿主机模型配置文件。
# Compose 会把它可写挂载为容器内 /workspace/models.yml，便于别名切换、灰度和回滚写回后持久化。
MODEL_CONFIG_HOST_FILE=./models.yml

# 容器内模型配置文件路径。
# 默认使用上面的 MODEL_CONFIG_HOST_FILE 挂载到 /workspace/models.yml。
MODEL_CONFIG_PATH=/workspace/models.yml

# 模型配置文件缺失、损坏或根节点格式错误时是否启动/重载失败，避免静默退化为空配置。
MODEL_CONFIG_READ_FAIL_CLOSED=true

# 单次请求允许的 tensor 最大元素数量。
# 默认 12582912 约等于 1 * 3 * 2048 * 2048，用于防止过大的 JSON 请求撑爆内存。
# 如果你的模型输入更大，需要按实际 shape 调整。
MAX_TENSOR_ITEMS=12582912

# 图片、离线视频、视频流业务接口限制。
# MAX_IMAGE_BYTES 控制单张上传图片最大字节数。
# MAX_PERSON_FRAMES 控制 /infer/persons 单次最多处理多少张帧图。
# MAX_EMBEDDING_IMAGES 控制 /infer/person-embeddings 单次最多处理多少张人体 crop。
# MAX_PIPELINE_FRAMES 控制 /infer/person-tracks 单次最多处理多少张帧图。
# MAX_VISION_IMAGES 控制 /vision/infer 和 /vision/batch-infer 单次最多处理多少张图。
# MAX_VIDEO_BYTES 控制 /infer/video/person-tracks 单个视频文件最大字节数。
# VIDEO_FRAME_INTERVAL 控制离线视频默认每隔多少帧抽 1 帧。
# MAX_VIDEO_FRAMES 控制离线视频单次最多抽取多少帧。
# STREAM_FRAME_INTERVAL 控制视频流默认每隔多少帧抽 1 帧。
# MAX_STREAM_FRAMES 控制视频流单次最多抽取多少帧。
# STREAM_READ_TIMEOUT_SECONDS 控制视频流单次读取的软超时时间。
# ALLOW_STREAM_URLS 控制是否允许服务端主动拉取视频流 URL；生产环境建议只在可信内网启用。
# ALLOW_PRIVATE_STREAM_HOSTS 控制是否允许 RTSP/HTTP 流地址使用私网、回环、链路本地等 IP 字面量。
# STREAM_ALLOWED_HOSTS 为空时不限制域名；配置后仅允许精确匹配或子域名匹配，多个域名用英文逗号分隔。
MAX_IMAGE_BYTES=10485760
MAX_PERSON_FRAMES=16
MAX_EMBEDDING_IMAGES=64
MAX_PIPELINE_FRAMES=16
MAX_VISION_IMAGES=16
MAX_VIDEO_BYTES=104857600
VIDEO_FRAME_INTERVAL=15
MAX_VIDEO_FRAMES=64
STREAM_FRAME_INTERVAL=15
MAX_STREAM_FRAMES=32
STREAM_READ_TIMEOUT_SECONDS=10
STREAM_WORKER_POLL_INTERVAL_SECONDS=5
STREAM_WORKER_MAX_RECONNECTS=3
MAX_REQUEST_BODY_BYTES=805306368
ALLOW_STREAM_URLS=false
ALLOW_PRIVATE_STREAM_HOSTS=false
STREAM_ALLOWED_HOSTS=

# 单个 worker 最多缓存多少个 ONNX 模型。
# 0 表示不限制，模型加载后会一直留在进程和 GPU 显存中，直到容器重启或手动 unload。
# 正整数表示启用 LRU 淘汰，超过数量时卸载最久未使用的模型。
MAX_LOADED_MODELS=0

# 单个 worker 内允许同时进入 GPU 推理段的请求数量。
# 1 最稳，适合显存紧张或延迟敏感场景。
# 增大可能提升吞吐，但也可能增加显存峰值和延迟抖动。
# 注意：这是全局信号量，仅用于未显式分配设备的边缘路径；
# 多卡场景下实际推理门控由下面的 per-device 信号量负责。
GPU_QUEUE_LIMIT=1

# 多 GPU 设备分配（单卡可忽略，保持默认即可）。
# GPU_DEVICE_IDS：本 worker 可用的 GPU 设备号列表，逗号分隔，如 "0,1,2,3"。
#   留空时回退到 CUDA_VISIBLE_DEVICES，再回退到 "0"。
#   服务会按模型名 sha256 哈希把各模型均匀分配到这些设备；
#   也可在 models.yml 用 runtime.device_id 为单个模型指定固定设备。
#   指定了不在列表内的设备号时，自动回退到列表中的第一个设备。
# GPU_QUEUE_LIMIT_PER_DEVICE：每个 GPU 设备各自的并发推理上限，
#   不设置时继承 GPU_QUEUE_LIMIT。每块卡拥有独立信号量，互不阻塞。
# 单卡部署：GPU_DEVICE_IDS=0（或留空），所有模型都分到设备 0，行为与单队列一致。
GPU_DEVICE_IDS=0
GPU_QUEUE_LIMIT_PER_DEVICE=1

# 单模型并发和排队超时。
# MODEL_CONCURRENCY_LIMIT 是默认单模型并发限制；也可以在 models.yml 的模型配置中使用
# max_concurrency 或 runtime.max_concurrency 覆盖。
# MODEL_QUEUE_TIMEOUT_SECONDS 为 0 表示不设置队列等待超时；正数表示超过该秒数返回 503。
MODEL_CONCURRENCY_LIMIT=1
MODEL_QUEUE_TIMEOUT_SECONDS=0

# TensorRT Execution Provider 支持。
# 需要运行环境里的 onnxruntime-gpu 实际包含 TensorrtExecutionProvider。
# 模型配置 runtime: tensorrt 时，必须设置 ENABLE_TENSORRT=true 才会启用。
ENABLE_TENSORRT=false
TENSORRT_ENGINE_CACHE_ENABLE=true
TENSORRT_ENGINE_CACHE_PATH=/tmp/tensorrt-engine-cache

# 宿主机运行期状态目录。
# Compose 会挂载到容器内 /workspace/runtime-state，用于保存审计日志等可持久化运行期文件。
RUNTIME_STATE_HOST_DIR=./runtime-state

# 灰度/别名变更审计 JSONL 文件路径。
ROLLOUT_AUDIT_PATH=/workspace/runtime-state/rollout-audit.jsonl

# PortraitHub v1 运行期持久化状态与审计。
RUNTIME_STATE_DIR=/workspace/runtime-state
PORTRAIT_GALLERY_STATE_PATH=/workspace/runtime-state/portrait-gallery.json
PORTRAIT_THRESHOLDS_STATE_PATH=/workspace/runtime-state/portrait-thresholds.json
PORTRAIT_AUDIT_PATH=/workspace/runtime-state/portrait-audit.jsonl
AUDIT_WRITE_FAIL_CLOSED=true
PORTRAIT_JOBS_STATE_PATH=/workspace/runtime-state/portrait-jobs.json
PORTRAIT_STREAMS_STATE_PATH=/workspace/runtime-state/portrait-streams.json

# 企业安全配置。
# API_TOKEN 是简单服务令牌；RBAC_ENABLED=true 后可启用 HS256 JWT + 角色权限。
# AUTH_REQUIRED=true 时，如果既未配置 API_TOKEN 也未启用可用 RBAC，受保护接口会拒绝访问。
# DEBUG_ENDPOINTS_ENABLED=false 时，/debug/model-output 不可访问。
# JWT_SECRET 建议使用长随机字符串。ENCRYPTION_KEY 配置后，本地对象存储 payload 会加密。
JWT_SECRET=
JWT_SECRET_ID=primary
JWT_SECRET_KEYRING=
JWT_ISSUER=portrait-hub
JWT_AUDIENCE=portrait-hub-api
JWT_REQUIRE_EXP=true
JWT_REQUIRE_ISS=true
JWT_REQUIRE_AUD=true
RBAC_ENABLED=false
AUTH_REQUIRED=true
DEBUG_ENDPOINTS_ENABLED=false
ENABLE_API_DOCS=false
TRUSTED_HOSTS=127.0.0.1,localhost,gpu-worker-0,gpu-worker-1
TENANT_HEADER_REQUIRED=true
JWT_REQUIRE_TENANT=true
ENCRYPTION_KEY=
ENCRYPTION_KEY_ID=primary
ENCRYPTION_KEYRING=
REQUIRE_ENCRYPTION=true

# 生产适配后端。
# 默认使用本地 JSON/本地向量搜索/本地文件对象存储，方便单机跑通。
# 推荐生产组合：
#   PORTRAIT_STORAGE_BACKEND=postgres
#   PORTRAIT_VECTOR_BACKEND=pgvector        # 中小规模；大规模可改为 qdrant
#   PORTRAIT_OBJECT_STORAGE_BACKEND=s3      # MinIO 或 S3-compatible storage
PORTRAIT_STORAGE_BACKEND=json
PORTRAIT_VECTOR_BACKEND=local
PORTRAIT_OBJECT_STORAGE_BACKEND=local
POSTGRES_DSN=
POSTGRES_CONNECT_TIMEOUT_SECONDS=3
QDRANT_URL=
QDRANT_API_KEY=
OBJECT_STORAGE_DIR=/workspace/runtime-state/objects
S3_ENDPOINT_URL=
S3_REGION=us-east-1
S3_BUCKET=
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=

# 任务队列和流事件。
TASK_QUEUE_BACKEND=local
TASK_QUEUE_STATE_PATH=/workspace/runtime-state/portrait-task-queue.jsonl
REDIS_URL=
STREAM_EVENT_STATE_PATH=/workspace/runtime-state/portrait-stream-events.jsonl
MODEL_CAPABILITIES_PATH=/workspace/model-capabilities.yml

# 运行治理。
# RATE_LIMIT_PER_MINUTE=0 表示关闭限流；开启后按 tenant + path 使用本地 token bucket。
# RATE_LIMIT_MAX_BUCKETS 和 RATE_LIMIT_BUCKET_TTL_SECONDS 控制本地限流 bucket 的内存上限与空闲清理。
# SECURITY_HEADERS_ENABLED=true 会给响应加安全头。
# DATA_RETENTION_DAYS 可作为外部清理任务的默认保留天数。
# STATE_READ_FAIL_CLOSED=true 时，已有本地 JSON 状态文件损坏或格式错误会让启动/重载失败，避免静默丢状态。
# STATE_WRITE_FAIL_CLOSED=true 时，本地 JSON 状态持久化失败会让请求失败，避免内存成功但落盘失败。
# MAX_PUBLIC_METADATA_* 控制用户可写 metadata/settings 的大小、深度、键数量和字符串长度。
RATE_LIMIT_PER_MINUTE=120
RATE_LIMIT_BURST=240
RATE_LIMIT_MAX_BUCKETS=10000
RATE_LIMIT_BUCKET_TTL_SECONDS=3600
SECURITY_HEADERS_ENABLED=true
CONTENT_SECURITY_POLICY="default-src 'self'; object-src 'none'; base-uri 'none'; frame-ancestors 'none'; form-action 'self'; img-src 'self' data:; style-src 'self' 'unsafe-inline'; script-src 'self'"
HSTS_ENABLED=true
HSTS_MAX_AGE_SECONDS=31536000
HSTS_INCLUDE_SUBDOMAINS=true
HSTS_PRELOAD=false
DATA_RETENTION_DAYS=0
STATE_READ_FAIL_CLOSED=true
STATE_WRITE_FAIL_CLOSED=true
MAX_PUBLIC_METADATA_BYTES=16384
MAX_PUBLIC_METADATA_DEPTH=6
MAX_PUBLIC_METADATA_KEYS=128
MAX_PUBLIC_METADATA_STRING_LENGTH=2048
MAX_AUDIT_PAYLOAD_BYTES=32768
MAX_AUDIT_DEPTH=6
MAX_AUDIT_KEYS=128
MAX_AUDIT_LIST_ITEMS=64
MAX_AUDIT_STRING_LENGTH=2048
API_LIST_DEFAULT_LIMIT=100
MAX_API_LIST_LIMIT=500
STREAM_EVENT_LIST_DEFAULT_LIMIT=100
MAX_STREAM_EVENT_LIST_LIMIT=200

# 容器启动时自动预热的模型列表。
# 格式：project_name/model_name.onnx，多个模型用英文逗号分隔。
# 示例：portrait_hub/yolov8n.onnx,portrait_hub/osnet_ibn_x1_0.onnx
# 留空表示不启动预热。
WARMUP_MODELS=

# 接口访问令牌。
# AUTH_REQUIRED=false 时，留空表示不启用鉴权，仅建议本机调试使用。
# 本 Compose 模板默认 AUTH_REQUIRED=true，因此生产/容器启动前应设置 API_TOKEN 或启用 RBAC。
# 生产环境建议设置为长随机字符串，例如 openssl rand -hex 32。
# 启用后，请求需携带 Authorization: Bearer <API_TOKEN> 或 X-API-Key: <API_TOKEN>。
API_TOKEN=

# worker 与宿主机 GPU 编号的绑定关系。
# 可通过 nvidia-smi 查看 GPU 编号。
# gpu-worker-0 会绑定 GPU_WORKER_0_DEVICE，默认 GPU 0。
# gpu-worker-1 会绑定 GPU_WORKER_1_DEVICE，默认 GPU 1。
GPU_WORKER_0_DEVICE=0
GPU_WORKER_1_DEVICE=1
STREAM_WORKER_GPU_DEVICES=none
