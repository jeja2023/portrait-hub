# PortraitHub 环境配置模板
# 使用方式：
#   cp .env.example .env
#   nano .env
#
# 注意：
# - docker compose 会自动读取同目录下的 .env。
# - 修改 .env 后，需要执行 docker compose up -d 让容器重新创建并加载新环境变量。
# - 生产环境不要把真实 .env 提交到 Git。

# 日志级别：DEBUG / INFO / WARNING / ERROR
LOG_LEVEL=INFO

# 宿主机模型共享目录。默认 ./models 表示本项目目录下的 models。容器内会只读挂载为 /models。
MODELS_HOST_DIR=./models

# 宿主机运行时模型配置文件。首次部署时从仓库 models.yml 初始化；控制台只写这个 Git 忽略目录中的副本。
MODEL_CONFIG_HOST_FILE=./runtime-state/models.yml

# 容器内模型配置文件路径。默认使用上面的 MODEL_CONFIG_HOST_FILE 挂载到 /workspace/models.yml。
MODEL_CONFIG_PATH=/workspace/models.yml

# 模型配置文件缺失、损坏或根节点格式错误时是否启动/重载失败，避免静默退化为空配置。
MODEL_CONFIG_READ_FAIL_CLOSED=true

# 单次请求允许的张量最大元素数量。默认 12582912 约等于 1 * 3 * 2048 * 2048，用于防止过大的 JSON 请求撑爆内存。
MAX_TENSOR_ITEMS=12582912

# 单张上传图片的最大字节数限制。
MAX_IMAGE_BYTES=10485760

# 单张图片解码后的最大像素数，防止压缩炸弹耗尽内存。
MAX_IMAGE_PIXELS=25000000

# /infer/persons 接口单次最多处理的帧图数量限制。
MAX_PERSON_FRAMES=16

# /infer/person-embeddings 接口单次最多处理的人体裁剪图像数量限制。
MAX_EMBEDDING_IMAGES=64

# /infer/person-tracks 接口单次最多处理的帧图数量限制。
MAX_PIPELINE_FRAMES=16

# /vision/infer 和 /vision/batch-infer 接口单次最多处理的图片数量限制。
MAX_VISION_IMAGES=16

# 批量比对接口单次最多接受的图片对数量。
MAX_COMPARE_BATCH_PAIRS=64

# 图片解码、图库批量搜索和批量比对的进程内并发上限。
MAX_IMAGE_DECODE_CONCURRENCY=4
MAX_GALLERY_SEARCH_BATCH_CONCURRENCY=4
MAX_COMPARE_BATCH_CONCURRENCY=2

# 通用推理结果上限和默认检测参数。
MAX_DETECTIONS=1000
MAX_TOP_K=100
DEFAULT_CONFIDENCE=0.25
DEFAULT_IOU=0.45

# 未显式指定模型时使用的默认项目和模型文件。
DEFAULT_DETECTOR_PROJECT=portrait_hub
DEFAULT_DETECTOR_ARTIFACT=yolov8n.onnx
DEFAULT_REID_ARTIFACT=osnet_ibn_x1_0.onnx

# 人体检测/特征提取能力初始化失败后的重试冷却时间（秒）。
RUNTIME_CAPABILITY_RETRY_COOLDOWN_SECONDS=60

# /infer/video/person-tracks 接口单个上传视频文件最大字节数限制。
MAX_VIDEO_BYTES=104857600

# 上传暂存按块读取大小；默认 1 MiB，避免把完整视频读入 Web 服务进程内存。
VIDEO_UPLOAD_CHUNK_BYTES=1048576

# 离线视频处理每隔多少秒采样 1 帧（按视频时间轴，不依赖帧率）。
VIDEO_SAMPLE_INTERVAL_SECONDS=1.0

# 离线视频处理每批推理的最大帧数。
VIDEO_INFERENCE_BATCH_SIZE=16

# 异步视频任务失败后的最大重试次数及重试退避时间（秒）。
VIDEO_JOB_MAX_RETRIES=2
VIDEO_JOB_RETRY_BACKOFF_SECONDS=0.25

# 视频任务处理中间进度的持久化节流间隔（秒）；<=0 表示不节流。
VIDEO_JOB_PROGRESS_PERSIST_INTERVAL_SECONDS=2.0

# 上传帧序列接口（/infer/gait、/compare/batch 等）单次最多接受的帧数。
MAX_VIDEO_FRAME_UPLOADS=64

# 视频流处理每隔多少秒采样 1 帧。
STREAM_SAMPLE_INTERVAL_SECONDS=1.0

# 视频流每批推理的最大帧数。
STREAM_INFERENCE_BATCH_SIZE=8

# 视频流单次读取帧的软超时时间（秒）。
STREAM_READ_TIMEOUT_SECONDS=10

# 视频流工作线程轮询视频流状态的时间间隔（秒）。
STREAM_WORKER_POLL_INTERVAL_SECONDS=5

# 视频流工作线程断开时的最大重连次数。
STREAM_WORKER_MAX_RECONNECTS=3

# 视频流工作进程状态租约的有效期（秒）。
STREAM_WORKER_LEASE_TTL_SECONDS=30

# 守护进程可以回收失效进程锁之前需要等待的时间（秒）。
STREAM_WORKER_PROCESS_LOCK_STALE_SECONDS=300

# 视频/流解码后端：auto（装了 PyAV 就用、否则 OpenCV）/ opencv / pyav。
# PyAV 提供帧精确的单遍顺序解码；任何后端不可用或出错都会优雅回退到 OpenCV。
VIDEO_DECODE_BACKEND=auto

# HTTP 请求体最大字节数限制，防范大请求撑爆内存。生产环境必须处于
# MAX_VIDEO_BYTES + 1 MiB 到 MAX_VIDEO_BYTES + 16 MiB 之间，用于容纳 multipart 元数据。
MAX_REQUEST_BODY_BYTES=117440512

# 无 CUDA/GPU 时是否自动回退到 CPUExecutionProvider。生产若必须强制 GPU，可设为 false。
CPU_FALLBACK_ENABLED=true

# 强制纯 CPU 推理。纯 CPU 主机建议设为 true：直接以 CPU 建会话，避免 onnxruntime-gpu
# 把 CUDA 误报为“可用”而导致模型被加载两次（先 CUDA 会话再丢弃重建）。搭配
# requirements-cpu.txt（CPU 版 onnxruntime）效果最佳。有可用 GPU 时保持 false。
FORCE_CPU=false

# 是否允许服务端主动拉取外部视频流 URL（如 RTSP/HTTP）；生产环境建议只在可信内网启用。
ALLOW_STREAM_URLS=false

# 是否允许视频流地址使用私网、回环、链路本地等 IP 字面量（如 127.0.0.1 或 192.168.x.x）。
ALLOW_PRIVATE_STREAM_HOSTS=false

# 视频流地址域名白名单。为空时不限制；配置后仅允许精确或子域名匹配，多个域名逗号分隔。
STREAM_ALLOWED_HOSTS=

# 视频流地址 IP 网段白名单，使用 CIDR 格式，多个网段逗号分隔；适合无域名的大规模局域网摄像头。
STREAM_ALLOWED_CIDRS=

# 是否允许事件回调（webhook）URL 指向私网、回环、链路本地等地址；生产环境保持 false 以防 SSRF。
ALLOW_PRIVATE_WEBHOOK_HOSTS=false

# 事件回调 URL 域名白名单。为空时不限制；配置后仅允许精确或子域名匹配，多个域名逗号分隔。
WEBHOOK_ALLOWED_HOSTS=

# 事件回调 IP 网段白名单，使用 CIDR 格式，多个网段逗号分隔。
WEBHOOK_ALLOWED_CIDRS=

# 单个工作进程最多缓存的 ONNX 模型数量。0 表示不限制；正整数表示启用 LRU 淘汰最久未使用的模型。
MAX_LOADED_MODELS=0

# 单个工作进程内允许同时进入 GPU 推理段的请求数量（全局信号量）。1 最稳，适合显存紧张场景。
GPU_QUEUE_LIMIT=1

# 当前工作进程可用的 GPU 设备号列表，逗号分隔，如 "0,1,2,3"。留空时回退到 CUDA_VISIBLE_DEVICES 或 "0"。
GPU_DEVICE_IDS=0

# 每个 GPU 设备各自的并发推理上限。不设置时继承 GPU_QUEUE_LIMIT。多卡场景下每块卡独立控制，互不阻塞。
GPU_QUEUE_LIMIT_PER_DEVICE=1

# 默认单模型并发限制。也可以在 models.yml 的模型配置中使用 max_concurrency 覆盖。
MODEL_CONCURRENCY_LIMIT=1

# 队列等待超时时间（秒）。0 表示不等待超时；正数表示超过该秒数返回 503。
MODEL_QUEUE_TIMEOUT_SECONDS=0

# 模型加载失败后的冷却秒数。某模型加载失败后，冷却窗口内的请求直接 503 快速失败，不再每次
# 重做昂贵的哈希计算和会话创建；窗口过后自动重试，实现加载失败自愈。0 表示关闭冷却（每次都重试）。
MODEL_LOAD_RETRY_COOLDOWN_SECONDS=30

# 是否启用 TensorRT 执行提供程序（EP）。需要环境包含 TensorrtExecutionProvider，且模型配置为 tensorrt。
ENABLE_TENSORRT=false

# 是否启用 TensorRT 引擎缓存，避免每次启动或重载都重新构建 TensorRT 引擎。
TENSORRT_ENGINE_CACHE_ENABLE=true

# TensorRT 引擎缓存的保存路径。
TENSORRT_ENGINE_CACHE_PATH=/tmp/tensorrt-engine-cache

# 宿主机运行期状态目录。Compose 会挂载到容器内 /workspace/runtime-state，保存可持久化的状态与审计日志等。
RUNTIME_STATE_HOST_DIR=./runtime-state

# 灰度与别名变更审计 JSONL 文件在容器内的路径。
ROLLOUT_AUDIT_PATH=/workspace/runtime-state/rollout-audit.jsonl

# 运行期持久化状态与审计数据的根目录路径。
RUNTIME_STATE_DIR=/workspace/runtime-state

# 管理前端“配置中心”保存的配置覆盖状态文件。该文件包含敏感配置时会限制为仅属主可读写。
ADMIN_CONFIG_STATE_PATH=/workspace/runtime-state/admin-configuration.json

# 人像库/图库状态的持久化 JSON 文件路径。
PORTRAIT_GALLERY_STATE_PATH=/workspace/runtime-state/portrait-gallery.json

# 本地 JSON 图库是否启用增量 WAL 写入；开启后变更先追加到 .wal.jsonl，再按阈值执行压缩合并。
PORTRAIT_GALLERY_WAL_ENABLED=true

# 图库 WAL 累积多少次变更后自动压缩合并成主 JSON 快照；0 表示不自动合并。
PORTRAIT_GALLERY_WAL_COMPACT_EVERY=250

# 人像比对阈值配置的持久化 JSON 文件路径。
PORTRAIT_THRESHOLDS_STATE_PATH=/workspace/runtime-state/portrait-thresholds.json

# 人像业务接口审计日志的 JSONL 文件路径。
PORTRAIT_AUDIT_PATH=/workspace/runtime-state/portrait-audit.jsonl

# 审计日志写入失败时是否终止服务/拒绝请求，避免审计在故障时被静默绕过。
AUDIT_WRITE_FAIL_CLOSED=true

# 人像异步任务（Jobs）状态的持久化 JSON 文件路径。
PORTRAIT_JOBS_STATE_PATH=/workspace/runtime-state/portrait-jobs.json

# 统一解析档案的本地 SQLite 索引路径；生产 PostgreSQL 后端不使用此文件。
PORTRAIT_ANALYSIS_ARCHIVE_DB_PATH=/workspace/runtime-state/portrait-analysis-archive.sqlite3
# 是否保存图片、视频和视频流的全部解析档案。
ANALYSIS_ARCHIVE_ENABLED=true
# 对象存储中的预览图最大边长；完整结果图不受此值影响。
ANALYSIS_ARCHIVE_PREVIEW_MAX_SIDE=480

# 已入队视频文件的持久暂存目录；Web 服务与独立视频任务工作进程必须共享该目录。
VIDEO_JOB_INPUT_DIR=/workspace/runtime-state/video-job-inputs

# 接入应用和人工复核标注的本地状态文件路径。
PORTRAIT_ACCESS_STATE_PATH=/workspace/runtime-state/portrait-access.json
PORTRAIT_REVIEW_STATE_PATH=/workspace/runtime-state/portrait-review-annotations.json

# 接入密钥轮换后旧密钥继续有效的宽限时间（秒）。
PORTRAIT_ACCESS_KEY_ROTATION_GRACE_SECONDS=300

# 接入应用调用统计批量刷盘间隔；<=0 时仅在关闭服务或显式保存时刷盘。
ACCESS_STATS_FLUSH_INTERVAL_SECONDS=5

# 视频流配置及运行期状态的持久化 JSON 文件路径。
PORTRAIT_STREAMS_STATE_PATH=/workspace/runtime-state/portrait-streams.json

# 每个视频流守护进程的锁目录；应置于共享运行时存储中。
STREAM_WORKER_LOCK_DIR=/workspace/runtime-state/stream-worker-locks

# 本地管理员账号仅用于初始部署/开发。默认 admin / 123456 只允许进程本机访问。
# Docker 或反向代理访问时，应用看到的通常是网桥地址：必须设置 LOCAL_AUTH_ALLOW_REMOTE=true，
# 同时更换默认密码和至少 32 字节的会话密钥，否则登录页会隐藏用户名/密码表单。
LOCAL_AUTH_ENABLED=true
LOCAL_AUTH_ALLOW_REMOTE=false
LOCAL_AUTH_USERNAME=admin
LOCAL_AUTH_PASSWORD=123456
LOCAL_AUTH_TENANT_ID=default
LOCAL_AUTH_SESSION_SECRET=portrait-hub-development-local-session-secret
LOCAL_AUTH_SESSION_MAX_AGE_SECONDS=28800
LOCAL_AUTH_COOKIE_SECURE=false

# 企业人员登录使用 OIDC Authorization Code + PKCE；系统接入仍使用 API Key。
OIDC_ENABLED=false
OIDC_ISSUER=
OIDC_CLIENT_ID=
OIDC_CLIENT_SECRET=
OIDC_REDIRECT_URI=https://portrait.example.com/auth/oidc/callback
OIDC_PROVIDER_NAME=企业账号
OIDC_SCOPES=openid profile email groups

# 将身份平台的角色/用户组映射到 admin/operator/algorithm/auditor/viewer。
OIDC_ROLE_CLAIM=roles
OIDC_GROUPS_CLAIM=groups
OIDC_TENANT_CLAIM=tenant_id
OIDC_ROLE_MAPPING={"portrait-admin":"admin","portrait-operator":"operator","portrait-algorithm":"algorithm","portrait-auditor":"auditor","portrait-viewer":"viewer"}
OIDC_DEFAULT_ROLE=
OIDC_DEFAULT_TENANT_ID=

# 至少 32 字节随机值；生产环境必须启用安全 Cookie 和 HTTPS。
OIDC_SESSION_SECRET=
OIDC_SESSION_COOKIE_NAME=portrait_oidc_session
OIDC_SESSION_MAX_AGE_SECONDS=28800
OIDC_HTTP_TIMEOUT_SECONDS=10
OIDC_COOKIE_SECURE=true
OIDC_ALLOW_INSECURE_HTTP=false

# 企业身份平台的用户/用户组管理地址，仅用于管理员跳转。
OIDC_IDENTITY_ADMIN_URL=
# HS256 JWT 签名的主密钥。建议使用长随机字符串。
JWT_SECRET=

# JWT 密钥标识符，用于标示当前正在使用的密钥版本，默认 primary。
JWT_SECRET_ID=primary

# JWT 历史/备用密钥环，用以支持密钥无缝轮转，格式为 id:secret，多个用逗号分隔。
JWT_SECRET_KEYRING=

# JWT 签名算法。默认 HS256；生产可切到 RS256/ES256 并配置公钥。
JWT_ALGORITHM=HS256

# RS/ES JWT 验签公钥内容或公钥文件路径，二选一。
JWT_PUBLIC_KEY=
JWT_PUBLIC_KEY_PATH=

# RS/ES JWT 公钥环，可使用 JSON 映射表或 kid=public_key 逗号分隔格式。
JWT_PUBLIC_KEYRING=

# JWT 签发者（iss 声明），默认为 portrait-hub。
JWT_ISSUER=portrait-hub

# JWT 接收者（aud 声明），默认为 portrait-hub-api。
JWT_AUDIENCE=portrait-hub-api

# 是否强制校验 JWT 过期时间（exp 声明）。
JWT_REQUIRE_EXP=true

# 是否强制校验 JWT 签发者（iss 声明）。
JWT_REQUIRE_ISS=true

# 是否强制校验 JWT 接收者（aud 声明）。
JWT_REQUIRE_AUD=true

# 是否启用基于角色的权限访问控制（RBAC）。如果为 true，将结合 JWT 进行接口级角色权限校验。
RBAC_ENABLED=false

# 是否强制开启 API 鉴权。若为 true 且未配置 API_TOKEN、同时未启用 RBAC，所有受保护接口将拒绝访问。
AUTH_REQUIRED=true

CONSOLE_WS_TICKET_TTL_SECONDS=60
CONSOLE_WS_TICKET_MAX_ENTRIES=4096

# 是否启用调试接口（如 /debug/model-output）。若为 false 则相关接口不可访问。
DEBUG_ENDPOINTS_ENABLED=false

# 是否启用 API 交互式文档页面（如 Swagger UI / ReDoc）。
ENABLE_API_DOCS=false

# 受信任的 Host 域名或 IP 列表，英文逗号分隔。用于防范 Host 头部攻击等。
TRUSTED_HOSTS=127.0.0.1,localhost,gpu-worker-0,gpu-worker-1
# 纯 CPU 编排使用独立的默认受信任主机列表，避免 GPU 配置中的 TRUSTED_HOSTS 遗漏 cpu-worker-0。
CPU_TRUSTED_HOSTS=127.0.0.1,localhost,cpu-worker-0,portrait-stream-worker

# 是否强制要求请求中必须携带租户请求头（例如 X-Tenant-ID），以实现多租户隔离。
TENANT_HEADER_REQUIRED=true

# 是否强制要求 JWT 令牌中必须包含租户声明，以防跨租户令牌滥用。
JWT_REQUIRE_TENANT=true

# 数据存储的对称加密密钥，配置后本地对象存储负载会加密保存。
ENCRYPTION_KEY=

# 存储加密密钥的标识符，用于密钥管理，默认 primary。
ENCRYPTION_KEY_ID=primary

# 存储加密的备用密钥环，用于解密历史数据或密钥轮转，格式为 id:key，多个用逗号分隔。
ENCRYPTION_KEYRING=

# 存储加密密钥派生算法及 PBKDF2 迭代次数。使用 32 字节 Base64 原始密钥时可改为 raw-base64。
ENCRYPTION_KDF=pbkdf2-sha256
ENCRYPTION_PBKDF2_ITERATIONS=210000

# 是否强制要求所有本地存储的对象都必须进行加密保存。
REQUIRE_ENCRYPTION=true

# /metrics 文本缓存秒数，降低 Prometheus 高频抓取时的拼接开销。
PROMETHEUS_METRICS_CACHE_SECONDS=5

# 是否启用 OpenTelemetry FastAPI 自动埋点。启用前需安装可选依赖并配置 OTLP 采集端。
OPENTELEMETRY_ENABLED=false
OTEL_SERVICE_NAME=portrait-hub
OTEL_EXPORTER_OTLP_ENDPOINT=

# 构建镜像时是否安装生产可选依赖（OpenTelemetry、PostgreSQL、Qdrant、Redis、S3）。
INSTALL_PROD_OPTIONAL=false

# 是否启用基于文件修改时间（mtime）的 models.yml / model-capabilities.yml 轻量热重载。
CONFIG_HOT_RELOAD_ENABLED=true

# /ready 是否执行依赖级联检查。默认 false，以保持公开就绪响应最小化。
READY_CHECK_DEPENDENCIES=false

# 当前运行模式。production/prod 会启用生产外部依赖硬门禁。
PORTRAIT_RUNTIME_PROFILE=development

# 生产运行模式是否要求 Postgres/pgvector 或 Qdrant/Redis/S3/OTel 全部外部化。
PRODUCTION_EXTERNAL_SERVICES_REQUIRED=true

# 核心人像业务数据存储后端类型（例如 json, postgres）。
PORTRAIT_STORAGE_BACKEND=json

# 人脸/人体特征向量检索后端类型（例如 local, pgvector, qdrant）。
PORTRAIT_VECTOR_BACKEND=local

# 生产运行模式是否拒绝使用本地向量后端。
PORTRAIT_REQUIRE_PRODUCTION_VECTOR_BACKEND=false

# 图片/视频等对象文件的存储后端类型（例如 local, s3）。
PORTRAIT_OBJECT_STORAGE_BACKEND=local

# PostgreSQL 数据库连接 DSN。当存储或向量检索配置为 postgres/pgvector 时必填。
POSTGRES_DSN=

# PostgreSQL 数据库连接超时时间（秒）。
POSTGRES_CONNECT_TIMEOUT_SECONDS=3

# PostgreSQL 连接池大小。
POSTGRES_POOL_MIN_SIZE=1
POSTGRES_POOL_MAX_SIZE=10

# pgvector HNSW 查询候选列表大小；实际值不会低于请求的 top_k。
PGVECTOR_HNSW_EF_SEARCH=100

# Qdrant 向量数据库服务地址。当向量检索配置为 qdrant 时必填。
QDRANT_URL=

# Qdrant 向量数据库鉴权 API Key。若 Qdrant 未启用鉴权则留空。
QDRANT_API_KEY=

# Qdrant 客户端是否优先使用 gRPC。
QDRANT_PREFER_GRPC=false

# 本地文件对象存储的主目录路径，用于存放上传的人脸/人体小图和文件。
OBJECT_STORAGE_DIR=/workspace/runtime-state/objects

# S3 兼容对象存储服务的端点 URL。当存储后端为 s3 时必填。
S3_ENDPOINT_URL=

# S3 存储桶所属的区域。
S3_REGION=us-east-1

# S3 存储桶名称。
S3_BUCKET=

# S3 访问密钥 ID。
S3_ACCESS_KEY_ID=

# S3 安全访问密钥。
S3_SECRET_ACCESS_KEY=

# 异步任务队列的后端类型（例如 local, redis）。
TASK_QUEUE_BACKEND=local

# 本地任务队列在容器内的状态持久化文件路径。仅在 TASK_QUEUE_BACKEND=local 时有效。
TASK_QUEUE_STATE_PATH=/workspace/runtime-state/portrait-task-queue.jsonl

# 本地持久任务队列目录；即使进程重启，未确认任务仍可继续消费。
TASK_QUEUE_DIR=/workspace/runtime-state/task-queue

# 工作进程崩溃后，处理中消息允许被其他工作进程重新认领的超时时间。
TASK_QUEUE_VISIBILITY_TIMEOUT_SECONDS=300
TASK_QUEUE_POLL_INTERVAL_SECONDS=0.5

# 本地直接运行可在 Web 服务进程内消费；Compose/生产部署应设为 false 并运行独立工作进程。
VIDEO_JOB_WORKER_IN_PROCESS=false

# Redis 连接字符串（例如 redis://:password@host:port/db）。启用 Redis 队列或流事件时配置。
REDIS_URL=

# 视频流事件日志本地持久化文件路径。
STREAM_EVENT_STATE_PATH=/workspace/runtime-state/portrait-stream-events.jsonl

# 模型能力定义配置文件的容器内路径。
MODEL_CAPABILITIES_PATH=/workspace/model-capabilities.yml

# 每分钟接口限流请求数上限。0 表示关闭限流；正整数表示按租户 + 路径进行本地限流。
RATE_LIMIT_PER_MINUTE=120

# 允许的最大并发突发流量上限（令牌桶容量）。
RATE_LIMIT_BURST=240

# 内存中最多维护的限流令牌桶数量上限，防止多租户请求撑爆内存。
RATE_LIMIT_MAX_BUCKETS=10000

# 空闲限流令牌桶在内存中的生存时间（秒），过期将被清理以释放空间。
RATE_LIMIT_BUCKET_TTL_SECONDS=3600

# 是否使用代理传入的 X-Forwarded-For 作为限流来源；仅在可信反向代理后开启。
RATE_LIMIT_TRUST_FORWARDED_FOR=false

# 是否启用安全响应头（例如 X-Frame-Options, X-Content-Type-Options）。
SECURITY_HEADERS_ENABLED=true

# 内容安全策略（CSP）响应头配置，防范跨站脚本攻击（XSS）等安全风险。
CONTENT_SECURITY_POLICY="default-src 'self'; object-src 'none'; base-uri 'none'; frame-ancestors 'none'; form-action 'self'; img-src 'self' data:; style-src 'self' 'unsafe-inline'; script-src 'self'"

# 是否启用 HTTP 严格传输安全（HSTS）响应头。
HSTS_ENABLED=true

# HSTS 头部的 max-age 参数，告知浏览器在多少秒内强制使用 HTTPS 访问。
HSTS_MAX_AGE_SECONDS=31536000

# HSTS 是否应用到所有子域名。
HSTS_INCLUDE_SUBDOMAINS=true

# 是否允许将本域名预载入浏览器的 HSTS 硬编码预载列表中。
HSTS_PRELOAD=false

# 历史数据默认保留天数。0 表示永久保留。
DATA_RETENTION_DAYS=0

# 启动或重载时，若本地已有的 JSON 状态文件损坏或格式错误，是否让服务启动/重载失败，避免静默丢失状态。
STATE_READ_FAIL_CLOSED=true

# 本地 JSON 状态持久化失败时是否让当前请求置为失败，避免内存数据与磁盘不一致。
STATE_WRITE_FAIL_CLOSED=true

# 是否要求所有模型能力在启动/重载时都由非回退的生产模型支持。
# 本地开发时保持 false，除非 model-capabilities.yml 中的每个能力都已可直接用于生产。
PORTRAIT_REQUIRE_PRODUCTION_MODEL_CAPABILITIES=false

# 用户可写入的单个公共元数据（metadata/settings）最大字节数限制。
MAX_PUBLIC_METADATA_BYTES=16384

# 用户可写入的公共元数据 JSON 最大嵌套深度。
MAX_PUBLIC_METADATA_DEPTH=6

# 用户可写入的公共元数据最大键数量限制。
MAX_PUBLIC_METADATA_KEYS=128

# 用户可写入的公共元数据中单个字符串的最大长度限制。
MAX_PUBLIC_METADATA_STRING_LENGTH=2048

# 审计日志中保存的请求/响应内容最大字节数限制。
MAX_AUDIT_PAYLOAD_BYTES=32768

# 审计日志内容的 JSON 最大嵌套深度限制。
MAX_AUDIT_DEPTH=6

# 审计日志内容中的最大键数量限制。
MAX_AUDIT_KEYS=128

# 审计日志内容中的最大数组/列表元素数量限制。
MAX_AUDIT_LIST_ITEMS=64

# 审计日志内容中单个字符串的最大长度限制。
MAX_AUDIT_STRING_LENGTH=2048

# API 列表分页接口的默认每页返回数量限制。
API_LIST_DEFAULT_LIMIT=100

# API 列表分页接口允许的每页返回数量上限。
MAX_API_LIST_LIMIT=500

# 视频流事件列表接口默认返回数量限制。
STREAM_EVENT_LIST_DEFAULT_LIMIT=100

# 视频流事件列表接口最大返回数量上限。
MAX_STREAM_EVENT_LIST_LIMIT=200

# 容器启动时自动加载并预热的模型列表。格式为 project_name/model_name.onnx，逗号分隔。
WARMUP_MODELS=

# 预热失败是否让进程启动失败。默认 false：预热尽力而为，单个模型失败只记录并继续预热其余模型，
# 避免一个坏模型拖垮整个服务启动。严格部署可设为 true，要求所有预热模型必须成功才允许启动。
WARMUP_FAIL_FAST=false

# 接口访问令牌。当 AUTH_REQUIRED=true 时，客户端请求需在请求头中携带此令牌才能通过鉴权。
API_TOKEN=

# 全局令牌默认只能访问此租户；生产使用全局令牌时必须配置。
API_TOKEN_TENANT_ID=

# 仅平台内部的受控运维场景可开启。开启后全局令牌可通过 X-Tenant-ID 选择租户。
API_TOKEN_ALLOW_TENANT_OVERRIDE=false

# gpu-worker-0 容器绑定的宿主机 GPU 编号。
GPU_WORKER_0_DEVICE=0

# gpu-worker-1 容器绑定的宿主机 GPU 编号。
GPU_WORKER_1_DEVICE=1

# 异步视频任务工作进程可见的 GPU 设备编号列表。GPU 编排会显式使用 NVIDIA runtime。
VIDEO_JOB_WORKER_GPU_DEVICES=0

# 视频流 worker 是否强制使用 CPU 执行推理。设为 false 时必须同时配置下面的 GPU 设备。
STREAM_WORKER_FORCE_CPU=true

# 视频流 worker 可见的 GPU 设备编号列表。默认 none，与 STREAM_WORKER_FORCE_CPU=true 配套使用。
STREAM_WORKER_GPU_DEVICES=none
